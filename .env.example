# Get a free MAP_KEY at: https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_MAP_KEY=your_map_key_here

# Data source (VIIRS_SNPP_NRT recommended, 375m resolution)
FIRMS_SOURCE=VIIRS_SNPP_NRT

# Bounding box: west,south,east,north
# Norden: 4,54,32,71
# Sverige: 10,55,25,69
# Europa: -10,35,40,72
FIRMS_AREA=4,54,32,71

# How many days of FIRMS data to fetch per ingestion run (max 10)
FIRMS_DAY_RANGE=3

# How often to fetch new data (hours)
FETCH_INTERVAL_HOURS=4

# Database URL
# SQLite (default, file may reset on Railway — use Postgres in production)
DATABASE_URL=sqlite+aiosqlite:///./fire_tracker.db
# Railway Postgres (add the Postgres plugin and Railway sets DATABASE_URL automatically):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Clustering parameters
CLUSTER_RADIUS_KM=2.0
CLUSTER_TIME_GAP_HOURS=48
ACTIVE_THRESHOLD_HOURS=48
